# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="AI Powered Client Hunt & Outreach"
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── AI API Keys ────────────────────────────────────────────────────────────────
# Groq API (fast LLM inference) — get key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI (optional alternative)
OPENAI_API_KEY=sk-your_openai_api_key_here

# ── OSM / Search ───────────────────────────────────────────────────────────────
OSM_CONTACT_EMAIL=your_email@gmail.com
OSM_DEFAULT_RADIUS=8000
OSM_MAX_RESULTS=200

# ── Gmail API Configuration (recommended) ─────────────────────────────────────
# Setup steps:
#   1. https://console.cloud.google.com/ → New Project → Enable Gmail API
#   2. OAuth consent screen → External → add your Gmail as test user
#   3. Credentials → Create OAuth 2.0 Client ID → Desktop app → Download JSON
#   4. Run: python scripts/gmail_auth.py --client-id ID --client-secret SECRET
#   5. Copy the printed GMAIL_REFRESH_TOKEN here
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your_client_secret
GMAIL_REFRESH_TOKEN=1//your_refresh_token
SMTP_FROM_NAME=Your Name or Company

# ── SMTP/IMAP Fallback (only needed if NOT using Gmail API above) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
