# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="AI Powered Client Hunt & Outreach"
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# ── Server ─────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database (Supabase PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Email Verification (Resend API) ────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noresponse@elvionsolutions.com
RESEND_FROM_NAME=Elvion Solutions

# ── AI API Keys ────────────────────────────────────────────────────────────────
# Groq API (fast LLM inference) — get key at https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI (optional alternative)
OPENAI_API_KEY=sk-your_openai_api_key_here

# ── OSM / Search ───────────────────────────────────────────────────────────────
OSM_CONTACT_EMAIL=your_email@gmail.com
OSM_DEFAULT_RADIUS=8000
OSM_MAX_RESULTS=200

# ── Gmail API Configuration (recommended) ─────────────────────────────────────
# Setup steps:
#   1. https://console.cloud.google.com/ → New Project → Enable Gmail API
#   2. OAuth consent screen → External → add your Gmail as test user
#   3. Credentials → Create OAuth 2.0 Client ID → Desktop app → Download JSON
#   4. Run: python scripts/gmail_auth.py --client-id ID --client-secret SECRET
#   5. Copy the printed GMAIL_REFRESH_TOKEN here
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your_client_secret
GMAIL_REFRESH_TOKEN=1//your_refresh_token
SMTP_FROM_NAME=Your Name or Company

# ── SMTP/IMAP Fallback (only needed if NOT using Gmail API above) ──────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── Google OAuth (for per-user email connections) ──────────────────────────────
# Create at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Type: OAuth 2.0 Client ID → Web Application
# Redirect URI: {BACKEND_URL}/api/v1/email-accounts/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret


# ── Encryption (for storing OAuth tokens & SMTP passwords securely) ────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, a key is derived from SECRET_KEY automatically
ENCRYPTION_KEY=

# ── URLs (for OAuth callbacks and frontend redirects) ──────────────────────────
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
